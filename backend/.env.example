# API Configuration
API_HOST=0.0.0.0
API_PORT=8080
DEBUG=false

# LLM
GEMINI_API_KEY=your-gemini-api-key

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/
DATABASE_NAME=spiritual_voice_bot
DATABASE_PASSWORD=your-db-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# CORS (comma-separated extra origins for Cloud Run)
ALLOWED_ORIGINS=

# RAG
RETRIEVAL_TOP_K=7
RERANK_TOP_K=3
MIN_SIMILARITY_SCORE=0.15

# Session
SESSION_TTL_MINUTES=60
